<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioGroup
            android:id="@+id/rgMode"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbMobile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mobile No."
                android:layout_marginStart="24dp" />
        </RadioGroup>

        <!-- ✅ Fixed: Properly defined mobile field -->
        <EditText
            android:id="@+id/etIdentifier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter username or mobile"
            android:inputType="phone"
            android:maxLength="10"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnFetchQuestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvSecQ"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Security Question"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etSecA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Security Answer"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etNewPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="New PIN"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:visibility="gone"
            android:layout_marginTop="6dp" />

        <Button
            android:id="@+id/btnConfirmReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset Password"
            android:layout_marginTop="12dp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
